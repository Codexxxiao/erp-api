  discountRate         Decimal? @db.Decimal(8, 4)
  discountAmount       Decimal  @default(0) @db.Decimal(18, 4)
  taxRate              Decimal? @db.Decimal(8, 4)
  taxAmount            Decimal  @default(0) @db.Decimal(18, 4)
  amount               Decimal  @default(0) @db.Decimal(18, 4)
  currencyCode         String?
  expectedDeliveryDate DateTime?
  remark               String?
  extra                Json?
  sort                 Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  contract SalesContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([contractId])
  @@index([sourceQuotationItemId])
  @@index([productId])
}

model SalesOrder {
  id                   String           @id @default(uuid())
  tenantId             String
  orderNo              String
  contractId           String?
  quotationId          String?
  customerId           String?
  customerName         String?
  customerContactId    String?
  customerContactName  String?
  subject              String
  status               SalesOrderStatus @default(DRAFT)
  currencyCode         String
  exchangeRate         Decimal?         @db.Decimal(18, 6)
  tradeTerm            String?
  paymentTerm          String?
  expectedDeliveryDate DateTime?
  ownerUserId          String?
  confirmedAt          DateTime?
  processingAt         DateTime?
  shippedAt            DateTime?
  completedAt          DateTime?
  cancelledAt          DateTime?
  subtotalAmount       Decimal          @default(0) @db.Decimal(18, 4)
  discountAmount       Decimal          @default(0) @db.Decimal(18, 4)
  taxAmount            Decimal          @default(0) @db.Decimal(18, 4)
  freightAmount        Decimal          @default(0) @db.Decimal(18, 4)
  otherAmount          Decimal          @default(0) @db.Decimal(18, 4)
  totalAmount          Decimal          @default(0) @db.Decimal(18, 4)
  remark               String?
  extra                Json?
  createdById          String
  updatedById          String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  contract SalesContract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  items    SalesOrderItem[]

  @@unique([tenantId, orderNo])
  @@index([tenantId])
  @@index([contractId])
  @@index([quotationId])
  @@index([customerId])
  @@index([status])
  @@index([ownerUserId])
  @@index([createdAt])
}

model SalesOrderItem {
  id                   String   @id @default(uuid())
  tenantId             String
  orderId              String
  sourceContractItemId String?
  sourceQuotationItemId String?
  productId            String?
  productCode          String?
  productNameCn        String?
  productNameEn        String?
  categoryCode         String?
  unitCode             String?
  orderedQuantity      Decimal  @db.Decimal(18, 4)
  shippedQuantity      Decimal  @default(0) @db.Decimal(18, 4)
  unitPrice            Decimal  @db.Decimal(18, 4)
  grossAmount          Decimal  @default(0) @db.Decimal(18, 4)
  discountAmount       Decimal  @default(0) @db.Decimal(18, 4)
  taxAmount            Decimal  @default(0) @db.Decimal(18, 4)
  amount               Decimal  @default(0) @db.Decimal(18, 4)
  currencyCode         String?
  expectedDeliveryDate DateTime?
  remark               String?
  extra                Json?
  sort                 Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  order SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([orderId])
  @@index([sourceContractItemId])
  @@index([sourceQuotationItemId])
  @@index([productId])
}