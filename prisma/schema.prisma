generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TenantStatus {
  TRIAL
  ACTIVE
  DISABLED
}

model Tenant {
  id        String       @id @default(uuid())
  name      String
  code      String       @unique
  status    TenantStatus @default(TRIAL)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  users        User[]
  invites      UserInvite[]
  roles        Role[]
  menus        Menu[]
  dictionaries Dictionary[]
  dataSources  DataSource[]
  forms        FormDefinition[]
  formRecords  FormRecord[]
}

model User {
  id                 String         @id @default(uuid())
  tenantId           String?
  identity           String         @unique
  username           String
  passwordHash       String
  nickname           String?
  isPlatformAdmin    Boolean        @default(false)
  isTenantAdmin      Boolean        @default(false)
  isActive           Boolean        @default(true)
  mustChangePassword Boolean        @default(false) // 新增：首次登录强制改密
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  tenant             Tenant?        @relation(fields: [tenantId], references: [id])
  refreshTokens      RefreshToken[]
  invitesSent        UserInvite[]   @relation("InviteCreator")
  invitesAccepted    UserInvite[]   @relation("InviteAcceptor")

  userRoles UserRole[]

  @@unique([tenantId, username])
  @@index([tenantId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  action    String
  resource  String?
  detail    Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([userId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserInvite {
  id           String    @id @default(uuid())
  tenantId     String
  username     String
  nickname     String?
  tokenHash    String    @unique
  expiresAt    DateTime
  acceptedAt   DateTime?
  acceptedById String?
  invitedById  String
  createdAt    DateTime  @default(now())
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy    User      @relation("InviteCreator", fields: [invitedById], references: [id])
  acceptedBy   User?     @relation("InviteAcceptor", fields: [acceptedById], references: [id])

  @@unique([tenantId, username])
  @@index([tenantId])
}

enum PermissionType {
  API
  MENU
  BUTTON
  DATA
}

enum MenuType {
  DIRECTORY
  PAGE
  BUTTON
}

model Permission {
  id          String         @id @default(uuid())
  code        String         @unique
  name        String
  module      String?
  type        PermissionType @default(API)
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  rolePermissions RolePermission[]
  menus           Menu[]
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  code        String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

model Menu {
  id             String   @id @default(uuid())
  tenantId       String
  parentId       String?
  type           MenuType @default(PAGE)
  title          String
  name           String
  path           String?
  component      String?
  redirect       String?
  icon           String?
  sort           Int      @default(0)
  permissionCode String?
  isVisible      Boolean  @default(true)
  isEnabled      Boolean  @default(true)
  meta           Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent     Menu?       @relation("MenuTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   Menu[]      @relation("MenuTree")
  permission Permission? @relation(fields: [permissionCode], references: [code])

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([parentId])
  @@index([permissionCode])
}

model Dictionary {
  id          String   @id @default(uuid())
  tenantId    String?
  scopeKey    String
  code        String
  name        String
  description String?
  sort        Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items  DictionaryItem[]

  @@unique([scopeKey, code])
  @@index([tenantId])
  @@index([scopeKey])
}

model DictionaryItem {
  id           String   @id @default(uuid())
  dictionaryId String
  parentId     String?
  value        String
  label        String
  color        String?
  sort         Int      @default(0)
  isActive     Boolean  @default(true)
  extra        Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  dictionary Dictionary       @relation(fields: [dictionaryId], references: [id], onDelete: Cascade)
  parent     DictionaryItem?  @relation("DictionaryItemTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   DictionaryItem[] @relation("DictionaryItemTree")

  @@unique([dictionaryId, value])
  @@index([dictionaryId])
  @@index([parentId])
}

enum DataSourceType {
  STATIC
  DICTIONARY
  INTERNAL
  HTTP
}

enum DataSourceFieldType {
  STRING
  NUMBER
  BOOLEAN
  DATE
  DATETIME
  JSON
}

model DataSource {
  id          String         @id @default(uuid())
  tenantId    String?
  scopeKey    String
  code        String
  name        String
  type        DataSourceType
  description String?
  config      Json
  sort        Int            @default(0)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fields DataSourceField[]

  @@unique([scopeKey, code])
  @@index([tenantId])
  @@index([scopeKey])
  @@index([code])
}

model DataSourceField {
  id           String              @id @default(uuid())
  dataSourceId String
  key          String
  label        String
  path         String
  type         DataSourceFieldType @default(STRING)
  isValue      Boolean             @default(false)
  isLabel      Boolean             @default(false)
  isExtra      Boolean             @default(true)
  sort         Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@unique([dataSourceId, key])
  @@index([dataSourceId])
}

enum FormStatus {
  DRAFT
  ENABLED
  DISABLED
}

enum FormTableType {
  MAIN
  SUB
}

enum FormFieldType {
  TEXT
  TEXTAREA
  NUMBER
  DECIMAL
  MONEY
  DATE
  DATETIME
  BOOLEAN
  DICTIONARY
  DATASOURCE
  USER
  ATTACHMENT
  IMAGE
}

model FormDefinition {
  id          String     @id @default(uuid())
  tenantId    String?
  scopeKey    String
  code        String
  name        String
  description String?
  status      FormStatus @default(DRAFT)
  version     Int        @default(1)
  layout      Json?
  config      Json?
  sort        Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  tenant  Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tables  FormTable[]
  records FormRecord[]

  @@unique([scopeKey, code])
  @@index([tenantId])
  @@index([scopeKey])
  @@index([code])
}

model FormTable {
  id        String        @id @default(uuid())
  formId    String
  parentId  String?
  code      String
  name      String
  type      FormTableType
  layout    Json?
  config    Json?
  sort      Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  form          FormDefinition     @relation(fields: [formId], references: [id], onDelete: Cascade)
  parent        FormTable?         @relation("FormTableTree", fields: [parentId], references: [id], onDelete: Cascade)
  children      FormTable[]        @relation("FormTableTree")
  fields        FormField[]
  recordDetails FormRecordDetail[]

  @@unique([formId, code])
  @@index([formId])
  @@index([parentId])
}

model FormField {
  id                String        @id @default(uuid())
  tableId           String
  code              String
  name              String
  type              FormFieldType
  required          Boolean       @default(false)
  unique            Boolean       @default(false)
  readonly          Boolean       @default(false)
  hidden            Boolean       @default(false)
  defaultValue      Json?
  dictionaryCode    String?
  dataSourceCode    String?
  dataSourceMapping Json?
  formula           Json?
  validationRules   Json?
  visibleWhen       Json?
  config            Json?
  sort              Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  table FormTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, code])
  @@index([tableId])
  @@index([code])
}

enum FormRecordStatus {
  DRAFT
  SUBMITTED
  CANCELED
}

model FormRecord {
  id          String           @id @default(uuid())
  tenantId    String
  formId      String
  formCode    String
  recordNo    String
  status      FormRecordStatus @default(DRAFT)
  mainData    Json
  createdById String
  updatedById String?
  submittedAt DateTime?
  canceledAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form    FormDefinition     @relation(fields: [formId], references: [id], onDelete: Restrict)
  details FormRecordDetail[]

  @@unique([tenantId, recordNo])
  @@index([tenantId])
  @@index([formId])
  @@index([formCode])
  @@index([status])
}

model FormRecordDetail {
  id        String   @id @default(uuid())
  recordId  String
  tableId   String
  tableCode String
  rowIndex  Int      @default(0)
  rowData   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  record FormRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  table  FormTable  @relation(fields: [tableId], references: [id], onDelete: Restrict)

  @@index([recordId])
  @@index([tableId])
  @@index([tableCode])
}


enum PhysicalSchemaStatus {
  DRAFT
  SYNCED
  FAILED
}

model FormPhysicalTable {
  id          String               @id @default(uuid())
  tenantId    String
  formId      String
  tableId     String
  formVersion Int
  tableCode   String
  tableName   String
  status      PhysicalSchemaStatus @default(DRAFT)
  lastError   String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  columns FormPhysicalColumn[]

  @@unique([tableId])
  @@unique([tenantId, tableName])
  @@index([tenantId])
  @@index([formId])
}

model FormPhysicalColumn {
  id              String   @id @default(uuid())
  physicalTableId String
  fieldId         String
  fieldCode       String
  columnName      String
  labelColumnName String?
  extraColumnName String?
  sqlType         String
  isRequired      Boolean  @default(false)
  isNullable      Boolean  @default(true)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  physicalTable FormPhysicalTable @relation(fields: [physicalTableId], references: [id], onDelete: Cascade)

  @@unique([physicalTableId, fieldId])
  @@unique([physicalTableId, columnName])
  @@index([fieldId])
}


enum DocumentFlowDirection {
  PUSH_DOWN
  IMPORT
}

enum DocumentFlowStatus {
  DRAFT
  ENABLED
  DISABLED
}

enum DocumentFlowMappingType {
  FIELD
  CONSTANT
}

enum DocumentFlowExecutionStatus {
  SUCCESS
  FAILED
}

enum DocumentFlowRepeatPolicy {
  BLOCK
  ALLOW
}

enum DocumentFlowLinkStatus {
  RESERVED
  SUCCESS
  FAILED
  CANCELED
}

model DocumentFlow {
  id           String                @id @default(uuid())
  tenantId     String
  code         String
  name         String
  direction    DocumentFlowDirection
  sourceFormId String
  targetFormId String
  status       DocumentFlowStatus    @default(DRAFT)
  repeatPolicy DocumentFlowRepeatPolicy @default(BLOCK)
  description  String?
  config       Json?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  mappings   DocumentFlowMapping[]
  executions DocumentFlowExecution[]
  links      DocumentFlowLink[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([sourceFormId])
  @@index([targetFormId])
}

model DocumentFlowLink {
  id             String                 @id @default(uuid())
  tenantId       String
  flowId         String
  sourceFormId   String
  sourceRecordId String
  sourceRecordNo String?
  targetFormId   String
  targetRecordId String?
  targetRecordNo String?
  status         DocumentFlowLinkStatus @default(RESERVED)
  dedupKey       String?
  errorMessage   String?
  createdById    String
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  flow       DocumentFlow            @relation(fields: [flowId], references: [id], onDelete: Cascade)
  executions DocumentFlowExecution[]

  @@unique([tenantId, flowId, dedupKey])
  @@index([tenantId])
  @@index([flowId])
  @@index([sourceRecordId])
  @@index([targetRecordId])
}

model DocumentFlowMapping {
  id              String                  @id @default(uuid())
  flowId          String
  sourceTableCode String?
  sourceFieldCode String?
  targetTableCode String?
  targetFieldCode String
  mappingType     DocumentFlowMappingType @default(FIELD)
  constantValue   Json?
  sort            Int                     @default(0)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  flow DocumentFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@index([sourceTableCode])
  @@index([targetTableCode])
}

model DocumentFlowExecution {
  id             String                      @id @default(uuid())
  tenantId       String
  flowId         String
  linkId         String?
  sourceFormId   String
  targetFormId   String
  sourceRecordId String
  targetRecordId String?
  status         DocumentFlowExecutionStatus
  payload        Json?
  errorMessage   String?
  createdById    String
  createdAt      DateTime                    @default(now())

  flow DocumentFlow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  link DocumentFlowLink? @relation(fields: [linkId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([flowId])
  @@index([linkId])
  @@index([sourceRecordId])
  @@index([targetRecordId])
}